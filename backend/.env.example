PORT=4100

# Firebase Admin — download from Firebase Console > Project Settings > Service Accounts
# > Generate new private key, save the file as backend/service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
FIREBASE_PROJECT_ID=fin-app26

# Working vendors
POLYGON_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=

# FRED (Federal Reserve Economic Data) — powers macro-events (Finnhub's
# /calendar/economic is confirmed blocked on the current plan, see
# FinnhubService). Free key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# SEC EDGAR requires no key, only a descriptive User-Agent per SEC fair-access policy
SEC_EDGAR_USER_AGENT=FinApp26 hello@inc108.com

# Adapter source selection — see backend/src/adapters/adapters.module.ts.
# Swapping these does NOT require any code, schema, or frontend changes.
# Every *_FALLBACK_SOURCE is tried automatically if the primary throws or
# has no data for a given ticker/request; set it to "none" to disable and
# fail fast on the primary alone. A successful fallback is never silent —
# the served document/response carries a FALLBACK_USED warning.
#
# COMPANY_PROFILE_SOURCE: "fmp" (default, full profile) | "polygon" (partial — no P/E/dividends/peers)
# COMPANY_PROFILE_FALLBACK_SOURCE: "polygon" (default) | "fmp" | "none"
# MOVERS_SOURCE: "polygon" (default, EOD-bar diff) | "fmp" (vendor-computed gainers/losers, no volume field) | "none"
# MOVERS_FALLBACK_SOURCE: "fmp" (default) | "polygon" | "none"
#   NOTE: FMP's biggest-gainers/biggest-losers endpoints are NOT YET
#   VERIFIED against this plan (unlike the other FMP endpoints already in
#   use) — see the caveat above FmpService.getBiggestGainers/getBiggestLosers.
# MOVER_ENRICHMENT_SOURCE: "fmp" (default, clean sector taxonomy) | "polygon" (free-text SIC description) | "none"
# MOVER_ENRICHMENT_FALLBACK_SOURCE: "polygon" (default) | "fmp" | "none"
COMPANY_PROFILE_SOURCE=fmp
COMPANY_PROFILE_FALLBACK_SOURCE=polygon
MOVERS_SOURCE=polygon
MOVERS_FALLBACK_SOURCE=fmp
MOVER_ENRICHMENT_SOURCE=fmp
MOVER_ENRICHMENT_FALLBACK_SOURCE=polygon

# Wave 2 — AI features, needs a key from console.anthropic.com
ANTHROPIC_API_KEY=

# Wave 3 — currently unset, stub modules log "not configured" until provided
BENZINGA_API_KEY=
TRADIER_ACCESS_TOKEN=
UNUSUAL_WHALES_API_KEY=
