rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Market Intelligence Platform — Firestore Security Rules
// Version: 1.0
//
// KEY DESIGN DECISIONS:
//
//  1. Subscription tier is stored as a Firebase Auth custom claim ({ tier: "pro" })
//     set by the backend (Firebase Admin SDK) whenever Stripe webhook fires.
//     Rules read request.auth.token.tier — zero extra Firestore reads per rule eval.
//
//  2. ALL market-data collections (news, earnings, analyst_actions, etc.) are
//     READ-ONLY for clients. Every write comes from ECS workers via Admin SDK,
//     which bypasses these rules entirely.
//
//  3. User sub-collections are isolated to the owning uid — no cross-user reads.
//
//  4. Field-level gating (e.g. aiNote on analyst_actions for Pro+ only) is
//     enforced at the API layer (Fastify), not here. Firestore rules cannot
//     strip individual fields from a document.
//
//  5. Watchlist 5-ticker limit for Free tier is enforced at the API layer.
//     Firestore rules cannot count sub-collection documents cheaply.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    // User must be signed in via Firebase Authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // The single fixed admin account, matched on the verified token email.
    // Kept in sync with ADMIN_EMAIL in deploy/env.production.yaml — the backend
    // AdminGuard checks the same address. Two places, one value: if you change
    // one, change both, or the admin screens and the admin API will disagree
    // about who is an admin.
    // Two accepted proofs, in order of preference:
    //
    //   1. A custom claim `admin: true`, set server-side via the Admin SDK.
    //      Independent of the email address, so rotating the admin's address
    //      needs no rules deploy.
    //   2. The fixed admin email — matching backend AdminGuard's ADMIN_EMAIL
    //      exactly. Kept so access works before the claim propagates (a client
    //      only sees a new claim after its ID token refreshes).
    //
    // NOTE: deliberately NOT requiring `email_verified`. The admin is a
    // password account created out-of-band and has emailVerified=false, so
    // demanding verification locked the admin out of their own console while
    // the backend guard still let the same account through. Verification adds
    // nothing here anyway: Firebase enforces email uniqueness, so nobody else
    // can register this address.
    function isAdmin() {
      return isAuthenticated()
             && (request.auth.token.admin == true
                 || request.auth.token.email == 'admin@marketcatalyst.ai');
    }

    // Request comes from the document owner
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Read subscription tier from custom claim (set by backend on Stripe events)
    // Defaults to "free" if claim is not yet set
    function tier() {
      return request.auth.token.get('tier', 'free');
    }

    function isFree() {
      return tier() == 'free';
    }

    function isProOrPremium() {
      return tier() in ['pro', 'premium'];
    }

    function isPremium() {
      return tier() == 'premium';
    }

    // Incoming data must not attempt to change uid or tier fields
    function noTierOrUidChange() {
      return !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['uid', 'tier', 'stripeCustomerId', 'stripeSubId']);
    }


    // ═════════════════════════════════════════════════════════════════════════
    // MARKET DATA COLLECTIONS — server writes only, tier-gated client reads
    // ═════════════════════════════════════════════════════════════════════════

    // Company reference data — all authenticated users
    match /companies/{ticker} {
      allow read:  if isAuthenticated();
      allow write: if false;  // Admin SDK only
    }

    // Feature flags — one doc read by every client so the UI can gate screens
    // live. Server-write-only (toggled via the backend Admin SDK).
    match /feature_flags/{doc} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // ── Subscriptions & billing ─────────────────────────────────────────────
    // Every collection below is written ONLY by the backend Admin SDK. Client
    // writes are refused outright: a client that could write `payments` or its
    // own `plans` document could grant itself a paid tier for free.

    // Pricing table — readable by all so the upgrade screen can render it.
    //
    // The admin may edit ENTITLEMENTS only. Price, currency and billing cycle
    // stay server-write-only: those must change together with the Stripe price
    // object, and a client that could rewrite `amount` could set a plan to $0
    // and subscribe to it. Entitlements carry no such risk — the worst case is
    // granting or revoking access, which is exactly what this control is for.
    match /plans/{planId} {
      allow read: if isAuthenticated();

      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['featureFlags', 'updatedAt'])
                    && request.resource.data.featureFlags is map;

      allow create, delete: if false;
    }

    // Payment records. A user may read their OWN payments (billing history);
    // only the admin may read across users.
    match /payments/{paymentId} {
      allow read:  if isAdmin()
                   || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // Subscription records, same visibility rule as payments.
    match /subscriptions/{subId} {
      allow read:  if isAdmin()
                   || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // ── Analytics ───────────────────────────────────────────────────────────
    // Read is admin-only: per-user API call logs and feature usage are
    // behavioural data about identifiable people, not market data.
    match /api_usage/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Feature adoption: one document per (feature, user), id `{feature}__{uid}`.
    //
    // Written by the CLIENT, unlike every other analytics collection here. The
    // browser cannot reach the backend yet (see POLYGON-FEATURE-CROSSCHECK §2.2),
    // so a server-mediated write is not available; the alternative was to ship
    // no adoption data at all.
    //
    // The trade-off is explicit: a signed-in user can inflate their OWN counters.
    // That is acceptable for adoption analytics — it is not billing, and the
    // blast radius is one user's own row. It is NOT acceptable for payments or
    // subscriptions, which stay server-write-only above. Move this server-side
    // once the Hosting rewrite lands.
    //
    // The rules below still pin down what may be written: the row must belong to
    // the caller, must carry the expected shape, and can never be deleted or
    // reassigned to another user.
    match /feature_adoption/{docId} {
      allow read: if isAdmin()
                  || (isAuthenticated() && resource.data.userId == request.auth.uid);

      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.feature is string
                    && request.resource.data.feature.size() <= 64
                    && request.resource.data.openCount is int
                    && request.resource.data.openCount >= 0;

      // Ownership cannot change hands, and the counter may only move forward —
      // so a client cannot rewrite history, only add to its own.
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.feature == resource.data.feature
                    && request.resource.data.openCount is int
                    && request.resource.data.openCount > resource.data.openCount;

      allow delete: if false;
    }

    match /revenue_summary/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Audit trail — admin-readable, never client-writable, never deletable.
    match /audit_logs/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    match /system_metrics/{docId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // Daily market breadth (advancers/decliners/TRIN) — Dashboard internals
    // + Fear-&-Greed history. Admin SDK only.
    match /market_breadth/{doc} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // 10-quarter financial statements per ticker — Stock Detail / Earnings.
    match /financials/{ticker} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Full US ticker universe (name/exchange/type/active/cik only — no
    // fundamentals; see companies/{ticker} for that) — all authenticated users
    match /tickers/{ticker} {
      allow read:  if isAuthenticated();
      allow write: if false;  // Admin SDK only
    }

    // Historical daily OHLCV bars — append-only, one immutable doc per
    // (ticker, date). Feeds Stock Detail's chart; a future RS-Rating
    // computation depends on this accumulating history first.
    match /ohlcv_bars/{barId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Intraday aggregate bars — ONE doc per (ticker, resolution) holding an
    // array of bars, not a doc per bar. Feeds the 1D/1W/1M chart timeframes,
    // which rendered a synthetic random walk before this collection existed.
    match /intraday_bars/{barsId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Declared dividend history per ticker (payments, annual totals, CAGR,
    // increase streak) — Stock Detail's dividend card/drawer and the Macro
    // dividend drawer, all of which previously extrapolated from one amount.
    match /dividend_history/{ticker} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Split history per ticker. No UI consumer yet — declared here so the read
    // is allowed when one lands, since the default-deny at the bottom of this
    // file would otherwise fail it silently.
    match /splits/{ticker} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Earnings calendar + actuals — all authenticated users
    match /earnings_events/{eventId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // AI-generated earnings summaries
    // TODO(tier-gating): restore `isProOrPremium()` once Stripe/subscriptions
    // are wired up. Relaxed to all authenticated users during the backend
    // migration since no code sets the `tier` custom claim yet.
    match /earnings_summaries/{summaryId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // News feed — all authenticated users
    match /news/{newsId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Analyst upgrades/downgrades — all authenticated users
    // (aiNote field stripped by API middleware for Free users)
    match /analyst_actions/{actionId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Macro/economic calendar — all authenticated users
    match /macro_events/{eventId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Market movers snapshots — all authenticated users
    match /market_movers/{moverId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Append-only history of market_movers — one immutable doc per
    // (date, direction, ticker), never overwritten by a later sync.
    match /market_movers_history/{docId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Options flow (unusual activity)
    // TODO(tier-gating): restore `isProOrPremium()` once Stripe/subscriptions exist.
    match /options_flow/{flowId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Block trades
    // TODO(tier-gating): restore `isProOrPremium()` once Stripe/subscriptions exist.
    match /block_trades/{tradeId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // 13F fund holdings
    // Covers fund document, filings sub-collection, and positions sub-sub-collection
    // TODO(tier-gating): restore `isProOrPremium()` once Stripe/subscriptions exist.
    match /fund_holdings/{cik} {
      allow read:  if isAuthenticated();
      allow write: if false;

      match /filings/{filingId} {
        allow read:  if isAuthenticated();
        allow write: if false;

        match /positions/{ticker} {
          allow read:  if isAuthenticated();
          allow write: if false;
        }
      }
    }

    // Story stocks
    // TODO(tier-gating): restore `isPremium()` once Stripe/subscriptions exist.
    match /story_stocks/{storyId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // EOD and weekly recaps
    // TODO(tier-gating): restore `isProOrPremium()` once Stripe/subscriptions exist.
    match /recaps/{recapId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Live market indices (S&P 500, Nasdaq, VIX, yields, commodities, DXY, etc.)
    match /market_indices/{symbol} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Append-only history of market_indices — one immutable doc per
    // (date, symbol), never overwritten by a later sync.
    match /market_indices_history/{docId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Sector heatmap / theme performance
    match /sectors/{sectorId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Append-only history of sectors — one immutable doc per (date, sector),
    // never overwritten by a later sync.
    match /sectors_history/{docId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // IPO calendar (recent + pipeline)
    match /ipos/{ipoId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Dividend calendar
    match /dividends/{ticker} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Form 4 insider transactions (individual buy/sell rows)
    match /insider_transactions/{id} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Options chain reference data — real strikes/expirations + delayed
    // last close/volume per contract (Polygon). Bid/ask, IV, greeks, and
    // open interest are NOT here — confirmed 403 on the current Polygon
    // plan; options.tsx's main chain table stays simulated for those.
    match /options_chains/{ticker} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Composite Fear & Greed reading (fear-greed.job → market_sentiment/fear_greed).
    // This collection had NO rule, so the default-deny at the bottom of this file
    // silently rejected every read and the Dashboard gauge fell back to its
    // hardcoded 62/"Greed" — the job has been writing real values the UI could
    // not see.
    match /market_sentiment/{docId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // Historical 4-component Fear & Greed composite (fear-greed.job →
    // market_sentiment_history/{date}) — drives the real F&G sparkline, replacing
    // the breadth-only proxy the Dashboard used to plot.
    match /market_sentiment_history/{docId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }


    // ═════════════════════════════════════════════════════════════════════════
    // USER COLLECTIONS — scoped strictly to owning uid
    // ═════════════════════════════════════════════════════════════════════════

    // User notes pinned to a chart. Each doc carries its owner's `uid`. Also
    // previously unmatched, so the notes feature failed silently on every
    // read and write.
    match /stock_comments/{docId} {
      allow read, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() <= 2000
                    && request.resource.data.sym is string;
      allow update: if false; // notes are immutable — delete and re-create to edit
    }

    match /users/{uid} {
      // The user reads their own profile; the admin reads across users to
      // populate the Users / Subscriptions / Revenue screens. Read only — the
      // admin console never mutates a subscription from the client, because a
      // tier change must go through the backend so it is audited and so
      // `featureFlags` stays consistent with the plan.
      allow read: if isOwner(uid) || isAdmin();

      // Create: server creates user doc on first sign-in via Admin SDK.
      // Allow client create only if uid matches and required fields are present.
      allow create: if isOwner(uid)
                    && request.resource.data.keys().hasAll(['uid', 'email', 'tier', 'createdAt'])
                    && request.resource.data.tier == 'free';  // always starts free

      // Update: user can update display name / photo only; tier + stripe fields are server-only
      allow update: if isOwner(uid) && noTierOrUidChange();

      // Hard deletes blocked — use deletedAt soft-delete via API
      allow delete: if false;


      // ── Portfolios ──────────────────────────────────────────────────────────
      match /portfolios/{portfolioId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(['name', 'createdAt']);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);

        // Holdings inside a portfolio
        match /holdings/{ticker} {
          allow read:   if isOwner(uid);
          allow create: if isOwner(uid)
                        && request.resource.data.keys().hasAll(['ticker', 'shares', 'addedAt']);
          allow update: if isOwner(uid);
          allow delete: if isOwner(uid);
        }
      }

      // ── Watchlists ─────────────────────────────────────────────────────────
      // Tier limit (Free = max 5 tickers per list) enforced at API layer.
      match /watchlists/{watchlistId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(['name', 'tickers', 'createdAt'])
                      && request.resource.data.tickers is list;
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Alert Rules ────────────────────────────────────────────────────────
      // 12 alert types available; which types are active depends on tier
      // (enforced at API layer, not here).
      match /alerts/{alertId} {
        allow read:   if isOwner(uid);
        allow create: if isOwner(uid)
                      && request.resource.data.keys().hasAll(['type', 'deliveryChannels', 'enabled', 'createdAt'])
                      && request.resource.data.type in [
                           'earnings', 'analyst', 'volume', 'price', '52wk_breakout',
                           'peer_move', 'macro_event', 'block_trade', '13f_filing',
                           'group_rs_rank', 'options_unusual', 'price_target_hit'
                         ]
                      && request.resource.data.deliveryChannels is list;
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Notifications ──────────────────────────────────────────────────────
      // Created by server (alert engine via Admin SDK).
      // Users can only mark as read (update 'read' field) or delete.
      match /notifications/{notificationId} {
        allow read:   if isOwner(uid);

        // Client can only flip read → true; all other fields are server-managed
        allow update: if isOwner(uid)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
                      && request.resource.data.read == true;

        // Clients can dismiss (delete) their own notifications
        allow delete: if isOwner(uid);

        // Creates come from Admin SDK only
        allow create: if false;
      }

    } // end /users/{uid}


    // ═════════════════════════════════════════════════════════════════════════
    // USER SETTINGS — per-user preferences (dark mode, etc.)
    // ═════════════════════════════════════════════════════════════════════════

    match /settings/{uid} {
      allow read, write: if isOwner(uid);
    }


    // ═════════════════════════════════════════════════════════════════════════
    // DENY ALL — catch-all for any path not explicitly matched above
    // ═════════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
